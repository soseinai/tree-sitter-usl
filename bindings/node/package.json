{
  "name": "tree-sitter-usl",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for USL (Universal Structure Language)",
  "main": "index.js",
  "types": "index.d.ts",
  "keywords": [
    "parser",
    "tree-sitter",
    "usl"
  ],
  "files": [
    "binding.gyp",
    "binding.cc",
